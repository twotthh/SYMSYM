{
  "manifest_version": 3,
  "name": "SYMSYM Security Alert",
  "version": "1.0.0",
  "description": "멀티 OSINT 기반 개인정보 노출 및 ASM 실시간 위협 알림 서비스",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
}
