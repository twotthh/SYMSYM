{
  "manifest_version": 3,
  "name": "SYMSYM",
  "version": "1.0.0",
  "description": "멀티 OSINT 기반 개인정보 노출 및 ASM 실시간 위협 알림 서비스",

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ]
}